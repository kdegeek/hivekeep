{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hivekeep",
  "version": "../package.json",
  "identifier": "com.marlburrow.hivekeep",
  "build": {
    "beforeDevCommand": "npm run dev:client",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hivekeep",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "marlburrow",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "Hivekeep"
      },
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "& { param($target) $script = if (Test-Path -LiteralPath 'scripts/sign-windows-tauri.ps1') { 'scripts/sign-windows-tauri.ps1' } else { '../scripts/sign-windows-tauri.ps1' }; & $script $target }",
          "%1"
        ]
      }
    }
  }
}
